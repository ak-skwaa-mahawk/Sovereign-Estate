{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": [
    "client/**/*",
    "server/**/*",
    "scripts/**/*"
  ],
  "exclude": [
    "node_modules",
    "whisper.cpp",
    "Feedback_processor_theory",
    "data",
    "dist",
    "build",
    "test/contracts.test.ts"
  ]
}
